{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/park.html", "destination": "/park", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/park/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
